<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:context="http://www.springframework.org/schema/context"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:mvc="http://www.springframework.org/schema/mvc"
       xsi:schemaLocation="

        http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans-3.0.xsd
        http://www.springframework.org/schema/context
        http://www.springframework.org/schema/context/spring-context-3.0.xsd">

    <context:component-scan base-package="com.fc572.domain"/>

    <bean id="viewResolver" class="org.springframework.web.servlet.view.InternalResourceViewResolver">
        <property name="prefix" value="/WEB-INF/pages/" />
        <property name="suffix" value=".jsp" />
    </bean>

    <context:annotation-config/> <!-- needed for autowired configuration -->
    <bean id="codesAreHereBean" class="com.fc572.domain.CodesAreHere"/>

    <bean id="stringBean" class="java.lang.String">
        <constructor-arg value=""/>
    </bean>

    <bean id="httpCodeController" class="com.fc572.controller.HttpCodesController">
        <constructor-arg ref="codesAreHereBean" index="0"/>
        <constructor-arg ref="stringBean" index="1"/>
    </bean>

    <bean id="userCommentBean" class="com.fc572.domain.UserComment">
        <constructor-arg ref="stringBean" index="0"/>
        <constructor-arg ref="stringBean" index="1"/>
        <constructor-arg ref="stringBean" index="2"/>
    </bean>

    <bean id="userCommentController" class="com.fc572.controller.UserCommentController">
        <constructor-arg ref="userCommentBean" index="0"/>
        <constructor-arg ref="userCommentRepoImpl" index="1"/>
    </bean>

</beans>

